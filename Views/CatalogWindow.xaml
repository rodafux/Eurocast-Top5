<Window x:Class="Top5.Views.CatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Top5.ViewModels"
        Title="Gestion du Catalogue (Machines, Pièces, Moules)" Height="600" Width="900" 
        WindowStartupLocation="CenterOwner" Background="#F5F6FA">

    <Window.DataContext>
        <viewModels:CatalogViewModel />
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Base de données du matériel" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="🏭 MACHINES" FontWeight="Bold" Foreground="#34495E" FontSize="14" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewMachine, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,5,0" />
                        <Button Grid.Column="1" Content="Ajouter" Command="{Binding AddMachineCommand}" Padding="10,5" Background="#2ECC71" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                    <ListBox Grid.Row="2" ItemsSource="{Binding Machines}" SelectedItem="{Binding SelectedMachine}" Margin="0,0,0,10" />
                    <Button Grid.Row="3" Content="🗑️ Supprimer sélection" Command="{Binding DeleteMachineCommand}" Padding="5" Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="5" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="⚙️ PIÈCES" FontWeight="Bold" Foreground="#34495E" FontSize="14" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewPiece, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,5,0" />
                        <Button Grid.Column="1" Content="Ajouter" Command="{Binding AddPieceCommand}" Padding="10,5" Background="#2ECC71" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                    <ListBox Grid.Row="2" ItemsSource="{Binding Pieces}" SelectedItem="{Binding SelectedPiece}" Margin="0,0,0,10" />
                    <Button Grid.Row="3" Content="🗑️ Supprimer sélection" Command="{Binding DeletePieceCommand}" Padding="5" Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </Border>

            <Border Grid.Column="4" Background="White" CornerRadius="5" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="🗜️ MOULES" FontWeight="Bold" Foreground="#34495E" FontSize="14" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewMoule, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,5,0" />
                        <Button Grid.Column="1" Content="Ajouter" Command="{Binding AddMouleCommand}" Padding="10,5" Background="#2ECC71" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                    <ListBox Grid.Row="2" ItemsSource="{Binding Moules}" SelectedItem="{Binding SelectedMoule}" Margin="0,0,0,10" />
                    <Button Grid.Row="3" Content="🗑️ Supprimer sélection" Command="{Binding DeleteMouleCommand}" Padding="5" Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Fermer" Click="BtnCancel_Click" Width="100" Height="35" Background="#95A5A6" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand"/>
            <Button Content="💾 Enregistrer les modifications" Command="{Binding SaveCommand}" Height="35" Padding="15,0" Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>