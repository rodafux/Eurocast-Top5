<Window x:Class="Top5.Views.PdfPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aperçu du Rapport Top 5" Height="850" Width="900" 
        WindowStartupLocation="CenterOwner" Background="#F3F3F3">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="10">
            <Button Content="🖨️ LANCER L'IMPRESSION" Click="BtnImprimer_Click" 
                    Background="#1976D2" Foreground="White" FontWeight="Bold" FontSize="14" 
                    Height="40" Width="300" Cursor="Hand" ToolTip="Générer le PDF ou imprimer sur papier"/>
        </Border>

        <FlowDocumentReader x:Name="Viewer" Grid.Row="1" Margin="5" ViewingMode="Scroll"/>

    </Grid>
</Window>