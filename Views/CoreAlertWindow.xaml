<Window x:Class="Top5.Views.CoreAlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚠️ ALERTE NOYAU CRITIQUE" Height="400" Width="700" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#FAFAFA" Topmost="True">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#E74C3C" CornerRadius="4" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="⚠️ ATTENTION : SUSPICION D'USURE ANORMALE DU NOYAU" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                <TextBlock Text="Ce numéro de noyau a déjà été déclaré comme Cassé, Plié ou HS récemment sur cette production" 
                           Foreground="White" TextWrapping="Wrap" TextAlignment="Center" Margin="0,5,0,0" FontSize="13"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="HistoryGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="80"/>
                <DataGridTextColumn Header="Heure" Binding="{Binding Heure}" Width="70"/>
                <DataGridTextColumn Header="Type de Défaut" Binding="{Binding TypeDefaut}" Width="150" FontWeight="Bold" Foreground="#E74C3C"/>
                <DataGridTextColumn Header="Par" Binding="{Binding Utilisateur}" Width="100"/>
                <DataGridTextColumn Header="Commentaire" Binding="{Binding Commentaire}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" Content="J'ai compris, continuer" Click="BtnOk_Click" Height="40" Width="200" HorizontalAlignment="Center" Margin="0,15,0,0" 
                Background="#34495E" Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand"/>
    </Grid>
</Window>