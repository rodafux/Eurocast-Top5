<Window x:Class="Top5.Views.DefectHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historique des Défauts par Pièce / Moule" Height="750" Width="1050" 
        WindowStartupLocation="CenterOwner" Background="#FAFAFA">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Recherche et Traçabilité des Défauts" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#333333"/>

        <Border Grid.Row="1" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,15">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="1. Sélection du fichier :" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,15,0" Foreground="#005A9E"/>

                    <TextBlock Text="Pièce:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox ItemsSource="{Binding AvailablePieces}" SelectedItem="{Binding SelectedPiece}" Width="150" Height="26" Margin="0,0,15,0"/>

                    <TextBlock Text="Moule:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox ItemsSource="{Binding AvailableMoules}" SelectedItem="{Binding SelectedMoule}" Width="150" Height="26"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="2. Filtres :" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,15,0" Foreground="#555555"/>

                    <TextBlock Text="Du:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker SelectedDate="{Binding StartDate}" Width="100" Margin="0,0,10,0"/>

                    <TextBlock Text="Au:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Width="100" Margin="0,0,15,0"/>

                    <TextBlock Text="Type:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding SearchDefectType, UpdateSourceTrigger=PropertyChanged}" Width="100" Height="24" Margin="0,0,10,0" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Noyau:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding SearchCoreNumber, UpdateSourceTrigger=PropertyChanged}" Width="50" Height="24" Margin="0,0,10,0" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Commentaire:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding SearchComment, UpdateSourceTrigger=PropertyChanged}" Width="120" Height="24" VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding FilteredDefects}" SelectedItem="{Binding SelectedDefect}" 
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                  Background="White" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE"
                  RowBackground="#FFFFFF" AlternatingRowBackground="#F9F9F9" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date du DMS" Binding="{Binding DateDms}" SortMemberPath="DateTimeDms" Width="100" Foreground="#005A9E" FontStyle="Italic" FontWeight="Bold"/>
                <DataGridTextColumn Header="Date d'Ajout" Binding="{Binding DateInitiale}" SortMemberPath="DateTimeInitiale" Width="100" Foreground="#005A9E"/>
                <DataGridTextColumn Header="Dernière Modif." Binding="{Binding Date}" SortMemberPath="DateTimeModif" Width="110" FontWeight="SemiBold"/>

                <DataGridTextColumn Header="Machine" Binding="{Binding Machine}" Width="90" FontWeight="Bold" Foreground="#2980B9"/>
                <DataGridTextColumn Header="Type" Binding="{Binding TypeDefaut}" Width="130" FontWeight="Bold"/>
                <DataGridTextColumn Header="Gravité" Binding="{Binding Gravite}" Width="70"/>
                <DataGridTextColumn Header="Noyau" Binding="{Binding NumeroNoyau}" Width="70" Foreground="#C0392B" FontWeight="Bold"/>
                <DataGridTextColumn Header="Commentaire" Binding="{Binding Commentaire}" Width="*"/>
                <DataGridTextColumn Header="Dernier Acteur" Binding="{Binding Utilisateur}" Width="100"/>
                <DataGridTextColumn Header="État" Binding="{Binding Action}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Text="Chronologie complète du défaut sélectionné :" FontWeight="Bold" Margin="0,15,0,5" Foreground="#005A9E"/>

        <DataGrid Grid.Row="4" ItemsSource="{Binding SelectedDefectTimeline}" 
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                  Background="#F0F4F8" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#DDDDDD"
                  RowBackground="#F0F4F8" AlternatingRowBackground="#E6EEF4" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Action Réalisée" Binding="{Binding Action}" Width="120" FontWeight="Bold" Foreground="#005A9E"/>

                <DataGridTextColumn Header="Date du DMS" Binding="{Binding DateDms}" SortMemberPath="DateTimeDms" Width="100" Foreground="#005A9E" FontStyle="Italic" FontWeight="Bold"/>
                <DataGridTextColumn Header="Date" Binding="{Binding Date}" SortMemberPath="DateTimeModif" Width="90"/>

                <DataGridTextColumn Header="Heure" Binding="{Binding Heure}" Width="70"/>
                <DataGridTextColumn Header="Machine" Binding="{Binding Machine}" Width="90" FontWeight="Bold" Foreground="#2980B9"/>
                <DataGridTextColumn Header="Par" Binding="{Binding Utilisateur}" Width="120" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Type" Binding="{Binding TypeDefaut}" Width="120"/>
                <DataGridTextColumn Header="Gravité" Binding="{Binding Gravite}" Width="70"/>
                <DataGridTextColumn Header="Noyau" Binding="{Binding NumeroNoyau}" Width="70" Foreground="#C0392B"/>
                <DataGridTextColumn Header="Commentaire à ce moment" Binding="{Binding Commentaire}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>