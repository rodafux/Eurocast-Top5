<Window x:Class="Top5.Views.DefectDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Top5.Converters"
        Title="Détails du défaut" Height="750" Width="600" 
        WindowStartupLocation="CenterOwner" Background="#F8F9FA">

    <Window.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <converters:StateToBrushConverter x:Key="StateToBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="StateRadioButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="#95A5A6" BorderThickness="1" Padding="25,10" Margin="5,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                <Setter TargetName="border" Property="Background" Value="#E5E7E9"/>
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="1.0"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#2C3E50"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.3"/>
                                <Setter Property="Cursor" Value="No"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15,20,15,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding SelectedDefectType, StringFormat='Défaut : {0}'}" FontSize="22" FontWeight="Bold" Foreground="#111111" Margin="5,0,0,20"
                   Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"/>

        <StackPanel Grid.Row="0" Visibility="{Binding IsCreationMode, Converter={StaticResource BoolToVis}}" Margin="5,0,0,20">
            <TextBlock Text="Nouveau Défaut :" FontSize="22" FontWeight="Bold" Foreground="#111111" Margin="0,0,0,10"/>
            <ComboBox ItemsSource="{Binding AvailableDefects}" SelectedItem="{Binding SelectedDefectType}" 
                      IsEditable="True" IsTextSearchEnabled="True" FontSize="14" Padding="5" Height="30"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Visibility="{Binding IsCoreNumberRequired, Converter={StaticResource BoolToVis}}" Margin="5,0,5,15">
            <TextBlock Text="Numéro de Noyau (Obligatoire) :" FontWeight="Bold" Foreground="#E74C3C" Margin="0,0,0,5"/>
            <TextBox Text="{Binding CoreNumber, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="5" BorderBrush="#E74C3C" BorderThickness="1" IsReadOnly="{Binding IsReadOnly}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20" IsEnabled="{Binding IsEditable}">
            <RadioButton Content="Validé" IsEnabled="{Binding IsEditMode}" IsChecked="{Binding SelectedState, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=B}" 
                         Style="{StaticResource StateRadioButton}" Background="#2ECC71"/>
            <RadioButton Content="À Améliorer" IsChecked="{Binding SelectedState, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=AA}" 
                         Style="{StaticResource StateRadioButton}" Background="#F39C12"/>
            <RadioButton Content="Non Conforme" IsChecked="{Binding SelectedState, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=NC}" 
                         Style="{StaticResource StateRadioButton}" Background="#E74C3C"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="Commentaire actuel :" FontWeight="Bold" FontSize="14" Foreground="#111111" Margin="5,0,0,5"/>

        <TextBox Grid.Row="4" Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" 
                 Height="90" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="{Binding IsReadOnly}" 
                 Margin="5,0,5,20" Padding="8" FontSize="13" Background="White" BorderBrush="#95A5A6" BorderThickness="1"/>

        <TextBlock Grid.Row="5" Text="Historique des modifications :" FontWeight="Bold" FontSize="14" Foreground="#111111" Margin="5,0,0,5"/>

        <DataGrid Grid.Row="6" ItemsSource="{Binding History}" AutoGenerateColumns="False" IsReadOnly="True" 
                  HeadersVisibility="Column" Background="White" BorderBrush="#B2BABB" BorderThickness="1" Margin="5,0,5,15"
                  RowBackground="#FFFFFF" AlternatingRowBackground="#FDFDFD" HorizontalGridLinesBrush="#E5E7E9" VerticalGridLinesBrush="#E5E7E9">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F2F3F4"/>
                    <Setter Property="Padding" Value="8,5"/>
                    <Setter Property="BorderBrush" Value="#B2BABB"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Foreground" Value="#333333"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding DateAffichee}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Qui ?" Binding="{Binding Utilisateur}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="État" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding StateValue, Converter={StaticResource StateToBrushConverter}}" 
                                    Margin="4,2" Padding="0,3">
                                <TextBlock Text="{Binding StateValue}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Commentaire" Binding="{Binding Commentaire}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="Padding" Value="5"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="7" Margin="5,5,5,0">
            <Button Content="🗑️ Supprimer" Click="BtnSupprimer_Click" HorizontalAlignment="Left" Width="120" Height="40" 
                    Background="#E74C3C" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand"
                    Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Fermer" Click="BtnAnnuler_Click" Width="100" Height="40" Background="#95A5A6" 
                        Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>

                <Button Content="💾 Enregistrer" Click="BtnValider_Click" Width="130" Height="40" Background="#3498DB" 
                        Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand"
                        Visibility="{Binding IsEditable, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>