<Window x:Class="Top5.Views.DefectDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Top5.Converters"
        Title="Saisie d'un défaut" Width="550" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" 
        Background="#F4F7F6" FontFamily="Segoe UI" FontSize="14">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />

        <SolidColorBrush x:Key="ColorOK" Color="#27AE60"/>
        <SolidColorBrush x:Key="ColorNCBack" Color="#FDEDEC"/>
        <SolidColorBrush x:Key="ColorNC" Color="#C0392B"/>

        <Style x:Key="ModernInputStyle" TargetType="Control">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D5DBDB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="RadioOKStyle" TargetType="RadioButton">
            <Setter Property="GroupName" Value="GravityGroup"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" BorderThickness="2" CornerRadius="5" Margin="5" Padding="5,10" Background="White" BorderBrush="#D5DBDB">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse x:Name="Dot" Fill="#27AE60" Width="12" Height="12" Margin="0,0,5,0"/>
                                <TextBlock x:Name="Txt" Text="VALIDÉ OK" FontWeight="Bold" FontSize="12" Foreground="Black"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EAFAF1"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#27AE60"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#27AE60"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1E8449"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                <Setter TargetName="Dot" Property="Fill" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RadioAAStyle" TargetType="RadioButton">
            <Setter Property="GroupName" Value="GravityGroup"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" BorderThickness="2" CornerRadius="5" Margin="5" Padding="5,10" Background="White" BorderBrush="#D5DBDB">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse x:Name="Dot" Fill="#E67E22" Width="12" Height="12" Margin="0,0,5,0"/>
                                <TextBlock x:Name="Txt" Text="A AMELIORER" FontWeight="Bold" FontSize="12" Foreground="Black"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FEF5E7"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E67E22"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E67E22"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#A04000"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                <Setter TargetName="Dot" Property="Fill" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RadioNCStyle" TargetType="RadioButton">
            <Setter Property="GroupName" Value="GravityGroup"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" BorderThickness="2" CornerRadius="5" Margin="5" Padding="5,10" Background="White" BorderBrush="#D5DBDB">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse x:Name="Dot" Fill="#C0392B" Width="12" Height="12" Margin="0,0,5,0"/>
                                <TextBlock x:Name="Txt" Text="NON CONFORME" FontWeight="Bold" FontSize="12" Foreground="Black"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FDEDEC"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#C0392B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C0392B"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#880E4F"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                <Setter TargetName="Dot" Property="Fill" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#EBEDEF" BorderThickness="0,0,0,1" Padding="20,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" FontSize="24" Foreground="{StaticResource ColorNC}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Nouveau Défaut" FontSize="20" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Padding="20">
            <StackPanel>

                <TextBlock Text="1. QUEL EST LE DÉFAUT ?" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,8" FontSize="12"/>
                <ComboBox ItemsSource="{Binding AvailableDefects}" 
                          SelectedItem="{Binding SelectedDefectType}" 
                          Text="{Binding SelectedDefectType, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          Height="40" 
                          Style="{StaticResource ModernInputStyle}" 
                          Margin="0,0,0,20"/>

                <TextBlock Text="2. QUELLE EST LA SÉVÉRITÉ ?" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,8" FontSize="12"/>
                <UniformGrid Columns="3" Margin="0,0,0,20" Height="65">
                    <RadioButton Style="{StaticResource RadioOKStyle}" IsChecked="{Binding SelectedState, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=B}"/>
                    <RadioButton Style="{StaticResource RadioAAStyle}" IsChecked="{Binding SelectedState, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=AA}"/>
                    <RadioButton Style="{StaticResource RadioNCStyle}" IsChecked="{Binding SelectedState, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=NC}"/>
                </UniformGrid>

                <Border Visibility="{Binding IsCoreNumberRequired, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Background="{StaticResource ColorNCBack}" 
                        BorderBrush="{StaticResource ColorNC}" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Padding="15" 
                        Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="⚠" Foreground="{StaticResource ColorNC}" FontWeight="Bold" Margin="0,0,5,0"/>
                            <TextBlock Text="NUMÉRO DE NOYAU OBLIGATOIRE" FontWeight="Bold" Foreground="{StaticResource ColorNC}"/>
                        </StackPanel>
                        <TextBox Text="{Binding CoreNumber, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="45" FontSize="22" FontWeight="Bold" TextAlignment="Center" VerticalContentAlignment="Center" 
                                 Background="White" BorderBrush="{StaticResource ColorNC}" BorderThickness="2" Style="{StaticResource ModernInputStyle}">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>
                </Border>

                <TextBlock Text="3. OBSERVATIONS / COMMENTAIRES" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,8" FontSize="12"/>
                <TextBox Text="{Binding Comment}" Height="80" Style="{StaticResource ModernInputStyle}" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#EBEDEF" Padding="20,15" BorderBrush="#D5DBDB" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="SUPPRIMER" Click="BtnSupprimer_Click" Width="110" Height="40" HorizontalAlignment="Left"
                        Background="#E74C3C" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Grid.Column="2" Content="ANNULER" IsCancel="True" Width="110" Height="40" Margin="0,0,10,0" HorizontalAlignment="Right"
                        Background="#95A5A6" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Grid.Column="3" Content="VALIDER LE DÉFAUT" Click="BtnValider_Click" Width="180" Height="40" HorizontalAlignment="Right"
                        Background="{StaticResource ColorOK}" Foreground="White" FontWeight="Bold" FontSize="15" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>