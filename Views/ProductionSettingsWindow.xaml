<Window x:Class="Top5.Views.ProductionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuration du Catalogue (Machines / Pièces / Moules)" Height="550" Width="800" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#FAFAFA">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Gestion du catalogue de production" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#333333"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Machines" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding Machines}" SelectedItem="{Binding SelectedMachine}" Margin="0,0,0,5" BorderBrush="#CCCCCC"/>
                <StackPanel Grid.Row="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewMachine, UpdateSourceTrigger=PropertyChanged}" Height="26" VerticalContentAlignment="Center" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="Ajouter" Command="{Binding AddMachineCommand}" Width="60" Height="26"/>
                    </Grid>
                    <Button Content="Supprimer la sélection" Command="{Binding DeleteMachineCommand}" Height="26" Margin="0,5,0,0" Background="#FADBD8" Foreground="#943126"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Pièces" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding Pieces}" SelectedItem="{Binding SelectedPiece}" Margin="0,0,0,5" BorderBrush="#CCCCCC"/>
                <StackPanel Grid.Row="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewPiece, UpdateSourceTrigger=PropertyChanged}" Height="26" VerticalContentAlignment="Center" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="Ajouter" Command="{Binding AddPieceCommand}" Width="60" Height="26"/>
                    </Grid>
                    <Button Content="Supprimer la sélection" Command="{Binding DeletePieceCommand}" Height="26" Margin="0,5,0,0" Background="#FADBD8" Foreground="#943126"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Moules" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding Moules}" SelectedItem="{Binding SelectedMoule}" Margin="0,0,0,5" BorderBrush="#CCCCCC"/>
                <StackPanel Grid.Row="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewMoule, UpdateSourceTrigger=PropertyChanged}" Height="26" VerticalContentAlignment="Center" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="Ajouter" Command="{Binding AddMouleCommand}" Width="60" Height="26"/>
                    </Grid>
                    <Button Content="Supprimer la sélection" Command="{Binding DeleteMouleCommand}" Height="26" Margin="0,5,0,0" Background="#FADBD8" Foreground="#943126"/>
                </StackPanel>
            </Grid>

        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Annuler" Width="90" Height="32" Margin="0,0,10,0" Click="BtnAnnuler_Click" Background="White"/>
            <Button Content="Enregistrer le catalogue" Command="{Binding SaveCommand}" Width="150" Height="32" Background="#0078D7" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>