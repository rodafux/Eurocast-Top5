<UserControl x:Class="Top5.Views.ShiftReportControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Top5.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:StateToBrushConverter x:Key="StateToBrushConverter" />

        <Style x:Key="FlatColorButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InvisibleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEEEEE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Padding="4" Margin="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="RX" Command="{Binding CycleStateCommand}" CommandParameter="RX" 
                        Background="{Binding RXState, Converter={StaticResource StateToBrushConverter}}" 
                        Style="{StaticResource FlatColorButtonStyle}" Width="35" Height="22" Margin="0,0,3,0"/>

                <Button Content="3D" Command="{Binding CycleStateCommand}" CommandParameter="3D" 
                        Background="{Binding DimensionalState, Converter={StaticResource StateToBrushConverter}}" 
                        Style="{StaticResource FlatColorButtonStyle}" Width="35" Height="22" Margin="0,0,3,0"/>

                <Button Content="AC" Command="{Binding CycleStateCommand}" CommandParameter="AC" 
                        Background="{Binding AspectState, Converter={StaticResource StateToBrushConverter}}" 
                        Style="{StaticResource FlatColorButtonStyle}" Width="35" Height="22" Margin="0,0,8,0"/>

                <TextBlock Text="Défauts:" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0" Foreground="#555555"/>

                <Button Content="+" Click="BtnAddDefect_Click" Width="20" Height="20" FontWeight="Bold" Background="#EFEFEF"/>

                <TextBlock Text="Avis NC:" ToolTip="Nombre d'Avis de Non Conformité" VerticalAlignment="Center" FontSize="11" Margin="15,0,4,0" Foreground="#555555"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="-" Command="{Binding DecrementANCCommand}" Width="18" Height="20" FontWeight="Bold" Background="#EFEFEF" BorderBrush="#CCCCCC" BorderThickness="1" Padding="0,-2,0,0"/>

                    <TextBlock Text="{Binding AncCount}" VerticalAlignment="Center" TextAlignment="Center" Width="20" FontSize="12" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#333333"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AncCount}" Value="0">
                                        <Setter Property="Foreground" Value="#333333"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Button Content="+" Command="{Binding IncrementANCCommand}" Width="18" Height="20" FontWeight="Bold" Background="#EFEFEF" BorderBrush="#CCCCCC" BorderThickness="1" Padding="0,-2,0,0"/>
                </StackPanel>
            </StackPanel>

            <ItemsControl Grid.Row="1" Grid.Column="0" ItemsSource="{Binding Defects}" Margin="0,0,8,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource InvisibleButtonStyle}" Margin="0,1"
                                Command="{Binding DataContext.EditDefectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}" ToolTip="Cliquer pour modifier ou supprimer">

                            <StackPanel Orientation="Vertical" Margin="0,2,0,4">

                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Fill="{Binding State, Converter={StaticResource StateToBrushConverter}}" Width="10" Height="10" Margin="0,0,4,0" Stroke="Black" StrokeThickness="0.5" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DefectType}" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding CoreNumber, StringFormat=' [Noyau n°{0}]'}" FontSize="11" FontWeight="Bold" Foreground="#C0392B" VerticalAlignment="Center" Margin="3,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CoreNumber}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CoreNumber}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Text="{Binding Comment, StringFormat='Obs: {0}'}" FontSize="11" FontStyle="Italic" Foreground="#666666" Margin="14,2,0,0" TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Comment}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Comment}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding GeneralComment, UpdateSourceTrigger=PropertyChanged}" 
                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="22" FontSize="11" Background="#FAFAFA" BorderBrush="#DDDDDD"
                     ToolTip="Commentaire général de l'équipe"/>
        </Grid>
    </Border>
</UserControl>