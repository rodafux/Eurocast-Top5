<Window x:Class="Top5.Views.ProductionHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historique des Changements de Productions" Height="600" Width="800" 
        WindowStartupLocation="CenterOwner" Background="#FAFAFA">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Historique des affectations de l'atelier" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#333333"/>

        <Border Grid.Row="1" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filtrer par :" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,15,0" Foreground="#555555"/>

                <TextBlock Text="Machine:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding SearchMachine, UpdateSourceTrigger=PropertyChanged}" Width="120" Height="24" Margin="0,0,15,0" VerticalContentAlignment="Center"/>

                <TextBlock Text="Pièce:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding SearchPiece, UpdateSourceTrigger=PropertyChanged}" Width="120" Height="24" Margin="0,0,15,0" VerticalContentAlignment="Center"/>

                <TextBlock Text="Moule:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding SearchMoule, UpdateSourceTrigger=PropertyChanged}" Width="120" Height="24" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding FilteredHistory}" AutoGenerateColumns="False" 
                  IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single"
                  Background="White" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE"
                  RowBackground="#FFFFFF" AlternatingRowBackground="#F9F9F9" HeadersVisibility="Column">

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding Timestamp, StringFormat='dd/MM/yyyy'}" Width="90" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Heure" Binding="{Binding Timestamp, StringFormat='HH:mm:ss'}" Width="80" Foreground="#666666"/>
                <DataGridTextColumn Header="Machine" Binding="{Binding Machine}" Width="150" FontWeight="Bold" Foreground="#005A9E"/>
                <DataGridTextColumn Header="Pièce" Binding="{Binding Piece}" Width="*"/>
                <DataGridTextColumn Header="Moule" Binding="{Binding Moule}" Width="*"/>
                <DataGridTextColumn Header="Type d'action" Binding="{Binding Action}" Width="150" FontStyle="Italic"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>